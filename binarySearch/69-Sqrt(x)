/*
LeetCode: 69
Problem: Sqrt(x)

Difficulty: Easy

Approach:
Binary Search

Time Complexity: O(log n)

Space Complexity: O(1)
*/
class Solution {
    public int mySqrt(int x) {
        int left=0;
        int right=x;
        while(left<=right){
            int mid=left+(right-left)/2;
            long square=(long) mid*mid;
            if(square==x){
                return mid;
            }
            if(square < x){
                left=mid+1;
            }else{
                right=mid-1;
            }
        }
        return right;

    }
}
